# SMTP credentials for the contact form (Nodemailer)
# For Gmail: enable 2FA, then create an App Password at https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
# Where contact form messages are delivered (defaults to SMTP_USER if omitted)
CONTACT_EMAIL=your-email@gmail.com
 